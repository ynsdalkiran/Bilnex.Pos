<UserControl x:Class="Bilnex.Pos.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="1000">
    <Border Padding="28"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrushDark}"
            BorderThickness="1"
            CornerRadius="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Inventory"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="32"
                               FontWeight="Bold" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Stock cards, movements and pricing controls"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="14" />
                </StackPanel>

                <Button DockPanel.Dock="Right"
                        Width="120"
                        Height="42"
                        Margin="24,0,0,0"
                        Command="{Binding DataContext.DashboardCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        Style="{StaticResource TileButtonStyle}"
                        Content="Back" />
            </DockPanel>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Padding="24"
                        Background="#111827"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="20">
                    <StackPanel>
                        <TextBlock Text="Inventory Overview"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="24"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,10,0,0"
                                   Text="Use this section for stock levels, low inventory warnings and product groups."
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="14"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Padding="24"
                        Background="#0F172A"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="20">
                    <StackPanel>
                        <TextBlock Text="Planned Modules"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="22"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,10,0,0"
                                   Text="Barcode setup, stock entry, count operations and supplier details can be added here."
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="14"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
