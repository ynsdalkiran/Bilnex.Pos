<UserControl x:Class="Bilnex.Pos.Views.PriceChangeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="1000">
    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto"
                  CanContentScroll="False">
    <Border MinWidth="860"
            MinHeight="540"
            Padding="28"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrushDark}"
            BorderThickness="1"
            CornerRadius="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Fiyat Değişimi"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="32"
                               FontWeight="Bold" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Toplu fiyat güncelleme ve onay akışı"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="14" />
                </StackPanel>

                <Button DockPanel.Dock="Right"
                        Width="120"
                        Height="42"
                        Margin="24,0,0,0"
                        Command="{Binding DashboardCommand}"
                        Style="{StaticResource CompactNavButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72B;"
                                   Margin="0,0,8,0"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="13"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Geri"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </DockPanel>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Border Padding="24"
                        Background="{DynamicResource ShellContentBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="20">
                    <StackPanel>
                        <TextBlock Text="Fiyat Yönetimi"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="24"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,12,0,0"
                                   Text="Bu ekran toplu fiyat artışı, indirim, kategori bazlı güncelleme ve onay senaryoları için ayrıldı."
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="14"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Padding="24"
                        Background="{DynamicResource ShellUserPanelBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="20">
                    <StackPanel>
                        <TextBlock Text="Sonraki Adımlar"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="22"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,14,0,0"
                                   Text="Kategori seçimi"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="Kategoriye veya markaya göre filtreli fiyat değişimi uygulanabilir."
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="13"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,18,0,0"
                                   Text="Onay ve log"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="Değişiklik önce onaya düşer, ardından sistem log kaydı oluşturur."
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="13"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
    </ScrollViewer>
</UserControl>
