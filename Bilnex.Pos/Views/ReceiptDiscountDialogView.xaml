<UserControl x:Class="Bilnex.Pos.Views.ReceiptDiscountDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1120">
    <Border Width="1120"
            MaxHeight="760"
            Padding="28"
            Background="{DynamicResource ShellContentBackgroundBrush}"
            BorderBrush="{StaticResource BorderBrushDark}"
            BorderThickness="1"
            CornerRadius="26"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Fi&#x015F; &#x0130;ndirimi"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="30"
                               FontWeight="Bold" />
                    <TextBlock Margin="0,6,0,0"
                               Text="Y&#x00FC;zde, tutar, yuvarlama ve haz&#x0131;r kampanyalar&#x0131; tek ekrandan uygulay&#x0131;n."
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="15" />
                </StackPanel>

                <Button DockPanel.Dock="Right"
                        Width="138"
                        Height="44"
                        Command="{Binding CloseReceiptDiscountCommand}"
                        Style="{StaticResource DangerActionButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE711;"
                                   Margin="0,0,8,0"
                                   FontFamily="Segoe MDL2 Assets"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Vazge&#x00E7;"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </DockPanel>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Padding="16"
                        Background="{DynamicResource WindowBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="18">
                    <StackPanel>
                        <TextBlock Text="Ara Toplam"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="13" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding ReceiptDiscountSubtotal, StringFormat={}{0:0.00} TL}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="26"
                                   FontWeight="Bold" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Padding="16"
                        Background="{DynamicResource WindowBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="18">
                    <StackPanel>
                        <TextBlock Text="&#x0130;ndirim"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="13" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding ReceiptDiscountValue, StringFormat={}{0:0.00} TL}"
                                   Foreground="{DynamicResource MetroTileOrangeBrush}"
                                   FontSize="26"
                                   FontWeight="Bold" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="4"
                        Padding="16"
                        Background="{DynamicResource WindowBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="18">
                    <StackPanel>
                        <TextBlock Text="Yuvarlama"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="13" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding ReceiptDiscountRoundAdjustment, StringFormat={}{0:0.00} TL}"
                                   Foreground="{DynamicResource MetroTilePurpleBrush}"
                                   FontSize="26"
                                   FontWeight="Bold" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="6"
                        Padding="16"
                        Background="{DynamicResource WindowBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="18">
                    <StackPanel>
                        <TextBlock Text="Yeni Toplam"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="13" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding ReceiptDiscountPreviewTotal, StringFormat={}{0:0.00} TL}"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   FontSize="28"
                                   FontWeight="Bold" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.45*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="0.95*" />
                </Grid.ColumnDefinitions>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False">
                    <Grid Margin="0,0,8,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Padding="18"
                                Background="{DynamicResource ShellUserPanelBackgroundBrush}"
                                BorderBrush="{StaticResource BorderBrushDark}"
                                BorderThickness="1"
                                CornerRadius="18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Haz&#x0131;r &#x0130;ndirimler"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="19"
                                               FontWeight="SemiBold" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="&#x00D6;zel m&#x00FC;&#x015F;teri, personel ve kampanya indirimlerini tek dokunu&#x015F;la uygula."
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="13"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Padding="12,8"
                                        Background="{DynamicResource WindowBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ReceiptDiscountLabel}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="13"
                                               FontWeight="SemiBold" />
                                </Border>
                            </Grid>
                        </Border>

                        <ItemsControl Grid.Row="2"
                                      ItemsSource="{Binding ReceiptDiscountPresets}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,12,12"
                                            MinHeight="74"
                                            Padding="16,14"
                                            Command="{Binding DataContext.SelectReceiptDiscountPresetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
                                                <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
                                                <Setter Property="BorderThickness" Value="1" />
                                            </Style>
                                        </Button.Style>
                                        <DockPanel LastChildFill="True">
                                            <Border DockPanel.Dock="Right"
                                                    Padding="10,6"
                                                    Background="{DynamicResource SurfaceAltBrush}"
                                                    CornerRadius="12"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ValueText}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold" />
                                            </Border>

                                            <StackPanel Margin="0,0,12,0">
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Margin="0,5,0,0"
                                                           Text="Standart kampanya"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="12" />
                                            </StackPanel>
                                        </DockPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Padding="18"
                                    Background="{DynamicResource ShellUserPanelBackgroundBrush}"
                                    BorderBrush="{StaticResource BorderBrushDark}"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Button Height="40"
                                            Command="{Binding SetReceiptDiscountInputTargetCommand}"
                                            CommandParameter="rate">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
                                                <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
                                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
                                                <Setter Property="BorderThickness" Value="1" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ReceiptDiscountInputTarget}" Value="rate">
                                                        <Setter Property="Background" Value="{DynamicResource MetroTileBlueBrush}" />
                                                        <Setter Property="Foreground" Value="White" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource MetroTileBlueBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="&#xE1D0;"
                                                       Margin="0,0,8,0"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="Y&#x00FC;zde &#x0130;ndirimi"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>

                                    <Grid Grid.Row="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="Fi&#x015F; toplam&#x0131;na y&#x00FC;zde bazl&#x0131; indirim uygular."
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />

                                        <TextBox Grid.Row="2"
                                                 Height="54"
                                                 Padding="14,10"
                                                 Text="{Binding ReceiptDiscountRateText, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="24"
                                                 FontWeight="SemiBold"
                                                 Background="{DynamicResource WindowBackgroundBrush}"
                                                 BorderBrush="{DynamicResource BorderBrushDark}"
                                                 BorderThickness="1"
                                                 VerticalContentAlignment="Center" />
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2"
                                    Padding="18"
                                    Background="{DynamicResource ShellUserPanelBackgroundBrush}"
                                    BorderBrush="{StaticResource BorderBrushDark}"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Button Height="40"
                                            Command="{Binding SetReceiptDiscountInputTargetCommand}"
                                            CommandParameter="amount">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
                                                <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
                                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
                                                <Setter Property="BorderThickness" Value="1" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ReceiptDiscountInputTarget}" Value="amount">
                                                        <Setter Property="Background" Value="{DynamicResource MetroTileBlueBrush}" />
                                                        <Setter Property="Foreground" Value="White" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource MetroTileBlueBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="&#xE1D1;"
                                                       Margin="0,0,8,0"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="Tutar &#x0130;ndirimi"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>

                                    <Grid Grid.Row="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="Fi&#x015F;ten do&#x011F;rudan TL bazl&#x0131; indirim d&#x00FC;&#x015F;er."
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />

                                        <TextBox Grid.Row="2"
                                                 Height="54"
                                                 Padding="14,10"
                                                 Text="{Binding ReceiptDiscountAmountText, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="24"
                                                 FontWeight="SemiBold"
                                                 Background="{DynamicResource WindowBackgroundBrush}"
                                                 BorderBrush="{DynamicResource BorderBrushDark}"
                                                 BorderThickness="1"
                                                 VerticalContentAlignment="Center" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>

                        <Border Grid.Row="6"
                                Padding="18"
                                Background="{DynamicResource ShellUserPanelBackgroundBrush}"
                                BorderBrush="{StaticResource BorderBrushDark}"
                                BorderThickness="1"
                                CornerRadius="18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Yuvarlama"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="19"
                                               FontWeight="SemiBold" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="Toplam&#x0131; kasada kolay tahsil edilecek hale getirmek i&#x00E7;in fi&#x015F;i yukar&#x0131; veya a&#x015F;a&#x011F;&#x0131; yuvarla."
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="13"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Height="48"
                                            Command="{Binding SetReceiptRoundModeCommand}"
                                            CommandParameter="Down">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
                                                <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
                                                <Setter Property="BorderThickness" Value="1" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ReceiptRoundMode}" Value="Down">
                                                        <Setter Property="Background" Value="{DynamicResource MetroTilePurpleBrush}" />
                                                        <Setter Property="Foreground" Value="White" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource MetroTilePurpleBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="&#xE74B;"
                                                       Margin="0,0,8,0"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="A&#x015F;a&#x011F;&#x0131; Yuvarla"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>

                                    <Button Grid.Column="2"
                                            Height="48"
                                            Command="{Binding SetReceiptRoundModeCommand}"
                                            CommandParameter="None">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
                                                <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
                                                <Setter Property="BorderThickness" Value="1" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ReceiptRoundMode}" Value="None">
                                                        <Setter Property="Background" Value="{DynamicResource MetroTileSlateBrush}" />
                                                        <Setter Property="Foreground" Value="White" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource MetroTileSlateBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="&#xE73E;"
                                                       Margin="0,0,8,0"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="Yuvarlama Yok"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>

                                    <Button Grid.Column="4"
                                            Height="48"
                                            Command="{Binding SetReceiptRoundModeCommand}"
                                            CommandParameter="Up">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
                                                <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
                                                <Setter Property="BorderThickness" Value="1" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ReceiptRoundMode}" Value="Up">
                                                        <Setter Property="Background" Value="{DynamicResource MetroTilePurpleBrush}" />
                                                        <Setter Property="Foreground" Value="White" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource MetroTilePurpleBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="&#xE74A;"
                                                       Margin="0,0,8,0"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="Yukar&#x0131; Yuvarla"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>

                <Border Grid.Column="2"
                        Padding="20"
                        Background="{DynamicResource ShellUserPanelBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Padding="18"
                                Background="{DynamicResource WindowBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrushDark}"
                                BorderThickness="1"
                                CornerRadius="18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Uygulama &#x00D6;zeti"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="20"
                                               FontWeight="SemiBold" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="{Binding ReceiptRoundModeText}"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="13" />
                                </StackPanel>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Padding="14"
                                            Background="{DynamicResource ShellContentBackgroundBrush}"
                                            CornerRadius="14">
                                        <StackPanel>
                                            <TextBlock Text="Se&#x00E7;ili Tan&#x0131;m"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="12" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding ReceiptDiscountLabel}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2"
                                            Padding="14"
                                            Background="{DynamicResource ShellContentBackgroundBrush}"
                                            CornerRadius="14">
                                        <StackPanel>
                                            <TextBlock Text="Giri&#x015F; Hedefi"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="12" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding ReceiptDiscountInputTargetText, StringFormat=Aktif alan: {0}}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="15"
                                                       FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border Grid.Row="4"
                                        Padding="16"
                                        Background="{DynamicResource ShellContentBackgroundBrush}"
                                        CornerRadius="16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="Tahsil Edilecek Yeni Toplam"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="12" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Text="{Binding ReceiptDiscountPreviewTotal, StringFormat={}{0:0.00} TL}"
                                                       Foreground="{DynamicResource PrimaryBrush}"
                                                       FontSize="32"
                                                       FontWeight="Bold" />
                                        </StackPanel>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding ReceiptDiscountValue, StringFormat=-{0:0.00} TL}"
                                                   Foreground="{DynamicResource MetroTileOrangeBrush}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Bottom" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                Padding="16"
                                Background="{DynamicResource WindowBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrushDark}"
                                BorderThickness="1"
                                CornerRadius="18">
                            <StackPanel>
                                <TextBlock Text="Numpad"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="19"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,4,0,0"
                                           Text="Se&#x00E7;ili alana h&#x0131;zl&#x0131; de&#x011F;er girmek i&#x00E7;in kullan."
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="13" />
                            </StackPanel>
                        </Border>

                        <UniformGrid Grid.Row="4"
                                     Rows="4"
                                     Columns="3">
                            <Button Margin="0,0,10,10" Command="{Binding AppendReceiptDiscountNumpadCommand}" CommandParameter="7" FontSize="24" FontWeight="Bold" Content="7" />
                            <Button Margin="0,0,10,10" Command="{Binding AppendReceiptDiscountNumpadCommand}" CommandParameter="8" FontSize="24" FontWeight="Bold" Content="8" />
                            <Button Margin="0,0,0,10" Command="{Binding AppendReceiptDiscountNumpadCommand}" CommandParameter="9" FontSize="24" FontWeight="Bold" Content="9" />
                            <Button Margin="0,0,10,10" Command="{Binding AppendReceiptDiscountNumpadCommand}" CommandParameter="4" FontSize="24" FontWeight="Bold" Content="4" />
                            <Button Margin="0,0,10,10" Command="{Binding AppendReceiptDiscountNumpadCommand}" CommandParameter="5" FontSize="24" FontWeight="Bold" Content="5" />
                            <Button Margin="0,0,0,10" Command="{Binding AppendReceiptDiscountNumpadCommand}" CommandParameter="6" FontSize="24" FontWeight="Bold" Content="6" />
                            <Button Margin="0,0,10,10" Command="{Binding AppendReceiptDiscountNumpadCommand}" CommandParameter="1" FontSize="24" FontWeight="Bold" Content="1" />
                            <Button Margin="0,0,10,10" Command="{Binding AppendReceiptDiscountNumpadCommand}" CommandParameter="2" FontSize="24" FontWeight="Bold" Content="2" />
                            <Button Margin="0,0,0,10" Command="{Binding AppendReceiptDiscountNumpadCommand}" CommandParameter="3" FontSize="24" FontWeight="Bold" Content="3" />
                            <Button Margin="0,0,10,0" Command="{Binding AppendReceiptDiscountNumpadCommand}" CommandParameter="," FontSize="24" FontWeight="Bold" Content="," />
                            <Button Margin="0,0,10,0" Command="{Binding AppendReceiptDiscountNumpadCommand}" CommandParameter="0" FontSize="24" FontWeight="Bold" Content="0" />
                            <Button Margin="0,0,0,0" Command="{Binding AppendReceiptDiscountNumpadCommand}" CommandParameter="00" FontSize="24" FontWeight="Bold" Content="00" />
                        </UniformGrid>

                        <Grid Grid.Row="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="1.25*" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Height="50"
                                    Command="{Binding ClearReceiptDiscountNumpadCommand}"
                                    Style="{StaticResource SecondaryActionButtonStyle}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE894;"
                                               Margin="0,0,8,0"
                                               FontFamily="Segoe MDL2 Assets"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Temizle"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="2"
                                    Height="50"
                                    Command="{Binding BackspaceReceiptDiscountNumpadCommand}"
                                    Style="{StaticResource SecondaryActionButtonStyle}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE94F;"
                                               Margin="0,0,8,0"
                                               FontFamily="Segoe MDL2 Assets"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Sil"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="4"
                                    Height="50"
                                    Command="{Binding ApplyReceiptDiscountCommand}"
                                    Style="{StaticResource SuccessActionButtonStyle}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE73E;"
                                               Margin="0,0,8,0"
                                               FontFamily="Segoe MDL2 Assets"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Fi&#x015F; &#x0130;ndirimini Uygula"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
