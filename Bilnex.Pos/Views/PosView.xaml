<UserControl x:Class="Bilnex.Pos.Views.PosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:Bilnex.Pos.Views"
             mc:Ignorable="d"
             Loaded="UserControl_Loaded"
             d:DesignHeight="600"
             d:DesignWidth="1000">
    <Grid MinWidth="880"
          MinHeight="560"
          FocusManager.FocusedElement="{Binding ElementName=BarcodeTextBox}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="10" />
            <RowDefinition Height="88" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="6*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.Column="0"
                Padding="16"
                Background="{DynamicResource ShellContentBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrushDark}"
                BorderThickness="1"
                CornerRadius="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="Sepet"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="24"
                                   FontWeight="Bold" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding ReceiptNo, StringFormat=Fiş: {0}}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="13" />
                    </StackPanel>

                    <Button DockPanel.Dock="Right"
                            Width="100"
                            Height="38"
                            Margin="12,0,0,0"
                            Command="{Binding DataContext.DashboardCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{StaticResource CompactNavButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72B;"
                                       Margin="0,0,8,0"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Geri"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </DockPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <TextBox x:Name="BarcodeTextBox"
                                 Height="40"
                                 Padding="10,7"
                                 Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="17"
                                 Background="{DynamicResource WindowBackgroundBrush}"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource BorderBrushDark}"
                                 BorderThickness="1"
                                 Focusable="True"
                                 VerticalContentAlignment="Center"
                                 PreviewTextInput="BarcodeTextBox_PreviewTextInput"
                                 PreviewKeyDown="BarcodeTextBox_PreviewKeyDown" />
                        <TextBlock Margin="14,0,0,0"
                                   Text="Barkod okut veya kod gir"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="14"
                                   IsHitTestVisible="False"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Barcode}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Barcode}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                    </Grid>

                    <Button Grid.Column="2"
                            Width="128"
                            Height="40"
                            Command="{Binding AddProductCommand}"
                            Background="{DynamicResource MetroTileBlueBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Click="RefocusBarcodeInput_Click"
                            ><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE1A7;" Margin="0,0,8,0" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" /><TextBlock Text="Barkodu Tara" VerticalAlignment="Center" /></StackPanel></Button>
                </Grid>

                <Border Grid.Row="4"
                        Padding="12,10"
                        Background="{DynamicResource ShellExitBackgroundBrush}"
                        BorderBrush="{DynamicResource ShellExitBackgroundBrush}"
                        BorderThickness="1"
                        CornerRadius="14">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LastInvalidBarcode}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding LastInvalidBarcode}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding LastInvalidBarcode}"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="SemiBold" />
                </Border>

                <DataGrid Grid.Row="6"
                          ItemsSource="{Binding BasketItems}"
                          SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserResizeColumns="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          HeadersVisibility="Column"
                          IsReadOnly="True"
                          GridLinesVisibility="None"
                          RowHeaderWidth="0"
                          RowHeight="44"
                          MinRowHeight="44"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          Background="{DynamicResource WindowBackgroundBrush}"
                          BorderBrush="{StaticResource BorderBrushDark}"
                          BorderThickness="1"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          FontSize="15">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                            <Setter Property="FontSize" Value="13" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                            <Setter Property="Padding" Value="12,10" />
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="10,6" />
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLastAdded}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                                </DataTrigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource MetroTileBlueBrush}" />
                                    <Setter Property="Foreground" Value="White" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="&#x00DC;r&#x00FC;n"
                                            Binding="{Binding ProductName}"
                                            Width="*"
                                            MinWidth="280">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="HorizontalAlignment" Value="Left" />
                                    <Setter Property="Margin" Value="2,0,0,0" />
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="Adet"
                                                Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid HorizontalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34" />
                                            <ColumnDefinition Width="44" />
                                            <ColumnDefinition Width="34" />
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0"
                                                Width="28"
                                                Height="28"
                                                Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Background="{DynamicResource MetroTileOrangeBrush}"
                                                Foreground="White"
                                                BorderThickness="0"
                                                Padding="0"
                                                HorizontalContentAlignment="Center"
                                                VerticalContentAlignment="Center"
                                                FontSize="14"
                                                FontWeight="Bold"
                                                Click="RefocusBarcodeInput_Click"
                                                Content="-" />

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Quantity}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />

                                        <Button Grid.Column="2"
                                                Width="28"
                                                Height="28"
                                                Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Background="{DynamicResource MetroTileGreenBrush}"
                                                Foreground="White"
                                                BorderThickness="0"
                                                Padding="0"
                                                HorizontalContentAlignment="Center"
                                                VerticalContentAlignment="Center"
                                                FontSize="14"
                                                FontWeight="Bold"
                                                Click="RefocusBarcodeInput_Click"
                                                Content="+" />
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Fiyat"
                                            Binding="{Binding UnitPrice, StringFormat={}{0:0.00}}"
                                            Width="96">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="Margin" Value="0,0,6,0" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Toplam"
                                            Binding="{Binding LineTotal, StringFormat={}{0:0.00}}"
                                            Width="112">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="Margin" Value="0,0,6,0" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="&#x0130;&#x015F;lem"
                                                Width="72">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Width="42"
                                            Height="28"
                                            Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Background="{DynamicResource ShellExitBackgroundBrush}"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Padding="0"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            FontSize="11"
                                            Style="{StaticResource DangerActionButtonStyle}"
                                            Click="RefocusBarcodeInput_Click"
                                            HorizontalAlignment="Center"
                                            ><StackPanel Orientation="Horizontal" HorizontalAlignment="Center"><TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" /></StackPanel></Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="0"
                Grid.Column="2"
                Padding="16"
                Background="{DynamicResource ShellUserPanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrushDark}"
                BorderThickness="1"
                CornerRadius="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <ItemsControl Grid.Row="0"
                              ItemsSource="{Binding ActionTabs}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1"
                                         Columns="3" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="0,0,10,0"
                                    MinHeight="42"
                                    Padding="10,0"
                                    Command="{Binding DataContext.SelectActionTabCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    BorderThickness="1"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Click="RefocusBarcodeInput_Click">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
                                        <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
                                        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource MetroTileBlueBrush}" />
                                                <Setter Property="Foreground" Value="White" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource MetroTileBlueBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="{Binding Title}"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center" />
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Grid Grid.Row="2">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsQuickProductsTabSelected}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <ItemsControl Grid.Row="0"
                                  ItemsSource="{Binding QuickProductCategories}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1"
                                             Columns="5" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="0,0,8,0"
                                        MinHeight="42"
                                        Padding="10,0"
                                        Command="{Binding DataContext.SelectQuickProductCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        BorderThickness="1"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Click="RefocusBarcodeInput_Click">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
                                            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
                                            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource MetroTileBlueBrush}" />
                                                    <Setter Property="Foreground" Value="White" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource MetroTileBlueBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="{Binding Title}"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center" />
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl Grid.Row="2"
                                  Margin="0,2,0,0"
                                  ItemsSource="{Binding QuickProducts}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button MinHeight="120"
                                        Margin="0,0,12,12"
                                        Padding="16"
                                        Background="{DynamicResource SurfaceAltBrush}"
                                        BorderBrush="{DynamicResource BorderBrushDark}"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        Command="{Binding DataContext.AddProductCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Click="RefocusBarcodeInput_Click"
                                        CommandParameter="{Binding Name}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="RootBorder"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="16">
                                                <Grid Margin="{TemplateBinding Padding}">
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               FontSize="19"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                                    <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="RootBorder" Property="RenderTransform">
                                                        <Setter.Value>
                                                            <ScaleTransform ScaleX="0.98" ScaleY="0.98" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

                <ItemsControl Grid.Row="2"
                              ItemsSource="{Binding VisibleActionItems}">
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsActionItemsTabSelected}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button MinHeight="86"
                                    Margin="0,0,10,10"
                                    Padding="14"
                                    Command="{Binding DataContext.TriggerPosActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    IsEnabled="{Binding IsEnabled}"
                                    BorderThickness="1"
                                    Click="RefocusBarcodeInput_Click">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryActionButtonStyle}">
                                        <Setter Property="Background" Value="{DynamicResource ShellContentBackgroundBrush}" />
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
                                        <Setter Property="HorizontalContentAlignment" Value="Left" />
                                    </Style>
                                </Button.Style>
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding Subtitle}"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="12"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </Grid>
        </Border>

        <Border Grid.Row="2"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Padding="12"
                Background="{DynamicResource ShellHeaderBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrushDark}"
                BorderThickness="1"
                CornerRadius="24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.7*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="0.95*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="0.95*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="0.9*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="18,10"
                        Background="{DynamicResource ShellUserPanelBackgroundBrush}"
                        CornerRadius="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="TOPLAM TUTAR"
                                       Foreground="{StaticResource TextMutedBrush}"
                                        FontSize="12"
                                       FontWeight="SemiBold" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding ItemCount}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="14" />
                        </StackPanel>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding TotalAmount, StringFormat={}{0:0.00}}"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <ItemsControl Grid.Column="2"
                              Grid.ColumnSpan="3"
                              ItemsSource="{Binding PaymentMethods}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1" Columns="2" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="0,0,10,0"
                                    Height="58"
                                    Command="{Binding DataContext.OpenPaymentMethodCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding Key}"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    FontSize="17"
                                    FontWeight="Bold"
                                    Click="RefocusBarcodeInput_Click"
                                    Content="{Binding Title}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="{DynamicResource MetroTileSlateBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Key}" Value="Cash">
                                                <Setter Property="Background" Value="{DynamicResource MetroTileGreenBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Key}" Value="Card">
                                                <Setter Property="Background" Value="{DynamicResource MetroTileBlueBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Grid.Column="6"
                        Content="Ödeme Al"
                        FontSize="17"
                        Padding="12,6"
                        FontWeight="Bold"
                        Background="{DynamicResource MetroTileTealBrush}"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Height="58"
                        Style="{StaticResource PrimaryActionButtonStyle}"
                        Click="RefocusBarcodeInput_Click"
                        Command="{Binding ReceivePaymentCommand}" />
            </Grid>
        </Border>

        <Border Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Background="#AA020617">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsReceiptDiscountScreenOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid>
                <views:ReceiptDiscountDialogView DataContext="{Binding}"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Border Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Background="#AA020617">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPaymentScreenOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid>
                <Border Width="560"
                        Padding="28"
                        Background="{DynamicResource ShellContentBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="26"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Ödeme Al"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="30"
                                           FontWeight="Bold" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding PaymentMethodTitle}"
                                           Foreground="{DynamicResource PrimaryBrush}"
                                           FontSize="16"
                                           FontWeight="SemiBold" />
                            </StackPanel>

                            <Button DockPanel.Dock="Right"
                                    Width="120"
                                    Height="42"
                                    Command="{Binding CancelPaymentCommand}"
                                    Background="{DynamicResource MetroTileOrangeBrush}"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Style="{StaticResource DangerActionButtonStyle}"
                                    ><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE711;" Margin="0,0,8,0" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" /><TextBlock Text="Vazgeç" VerticalAlignment="Center" /></StackPanel></Button>
                        </DockPanel>

                        <Border Grid.Row="2"
                                Padding="18"
                                Background="{DynamicResource WindowBackgroundBrush}"
                                CornerRadius="18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Ödenecek Tutar"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="14" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding ItemCount}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="15" />
                                </StackPanel>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding TotalAmount, StringFormat={}{0:0.00}}"
                                           Foreground="{DynamicResource PrimaryBrush}"
                                           FontSize="40"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="4">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCashPayment}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Alınan Tutar"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="16"
                                       FontWeight="SemiBold" />

                            <TextBox Grid.Row="2"
                                     Height="50"
                                     Padding="14,10"
                                     Text="{Binding ReceivedAmountText, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="22"
                                     Background="{DynamicResource WindowBackgroundBrush}"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderBrush="{StaticResource BorderBrushDark}"
                                     BorderThickness="1"
                                     VerticalContentAlignment="Center" />

                            <ItemsControl Grid.Row="4"
                                          ItemsSource="{Binding QuickAmounts}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="3" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Margin="0,0,10,10"
                                                Height="42"
                                                Command="{Binding DataContext.SetQuickReceivedAmountCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Value}"
                                                Foreground="White"
                                                BorderThickness="0"
                                                FontSize="15"
                                                FontWeight="SemiBold"
                                                Content="{Binding Title}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="{DynamicResource MetroTileSlateBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Value}" Value="TOTAL">
                                                            <Setter Property="Background" Value="{DynamicResource MetroTileTealBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <Border Grid.Row="6"
                                Padding="18"
                                Background="{DynamicResource ShellUserPanelBackgroundBrush}"
                                CornerRadius="18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Para Üstü"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="14" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding ChangeAmountText}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="28"
                                               FontWeight="Bold" />
                                </StackPanel>

                                <ItemsControl Grid.Column="1"
                                              Grid.ColumnSpan="3"
                                              ItemsSource="{Binding PaymentMethods}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="1" Columns="2" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Margin="0,0,18,0"
                                                    Height="52"
                                                    Command="{Binding DataContext.SelectPaymentMethodCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Key}"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    FontSize="20"
                                                    FontWeight="Bold"
                                                    Content="{Binding Title}">
                                                <Button.Style>
                                            <Style TargetType="Button">
                                                        <Setter Property="Background" Value="{DynamicResource MetroTileSlateBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Key}" Value="Cash">
                                                                <Setter Property="Background" Value="{DynamicResource MetroTileGreenBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Key}" Value="Card">
                                                                <Setter Property="Background" Value="{DynamicResource MetroTileBlueBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button Grid.Column="5"
                                        Width="150"
                                        Height="52"
                                        Command="{Binding CompletePaymentCommand}"
                                        Background="{DynamicResource MetroTileTealBrush}"
                                        Foreground="White"
                                        BorderThickness="0"
                                        FontSize="20"
                                        FontWeight="Bold"
                                        Style="{StaticResource SuccessActionButtonStyle}"
                                        ><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE73E;" Margin="0,0,8,0" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" /><TextBlock Text="Onayla" VerticalAlignment="Center" /></StackPanel></Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Background="#AA020617">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsHeldSalesScreenOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid>
                <Border Width="720"
                        Padding="28"
                        Background="{DynamicResource ShellContentBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="26"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Askıdaki Fişler"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="30"
                                           FontWeight="Bold" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding HeldSalesCountText}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="15" />
                            </StackPanel>

                            <Button DockPanel.Dock="Right"
                                    Width="120"
                                    Height="42"
                                    Command="{Binding CloseHeldSalesCommand}"
                                    Background="{DynamicResource MetroTileSlateBrush}"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Click="RefocusBarcodeInput_Click"
                                    Content="Kapat" />
                        </DockPanel>

                        <ListBox Grid.Row="2"
                                 ItemsSource="{Binding HeldSales}"
                                 Background="Transparent"
                                 BorderThickness="0">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,12" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="18"
                                            Background="{DynamicResource WindowBackgroundBrush}"
                                            BorderBrush="{StaticResource BorderBrushDark}"
                                            BorderThickness="1"
                                            CornerRadius="18">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="18" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="{Binding ReferenceNo}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="19"
                                                           FontWeight="Bold" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding ItemCount, StringFormat={}{0} ürün}"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="14" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Text="{Binding TimeText}"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="13" />
                                            </StackPanel>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding TotalAmount, StringFormat={}{0:0.00}}"
                                                       Foreground="{DynamicResource PrimaryBrush}"
                                                       FontSize="28"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center" />

                                            <Button Grid.Column="3"
                                                    Width="160"
                                                    Height="46"
                                                    Command="{Binding DataContext.RecallHeldSaleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="{DynamicResource MetroTileTealBrush}"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    FontSize="18"
                                                    FontWeight="SemiBold"
                                                    Click="RefocusBarcodeInput_Click"
                                                    Content="Geri Çağır" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Background="#AA020617">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsReceiptHistoryScreenOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid>
                <Border Width="760"
                        Padding="28"
                        Background="{DynamicResource ShellContentBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="26"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Tamamlanan Fişler"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="30"
                                           FontWeight="Bold" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding CompletedReceiptsCountText}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="15" />
                            </StackPanel>

                            <Button DockPanel.Dock="Right"
                                    Width="120"
                                    Height="42"
                                    Command="{Binding CloseReceiptHistoryCommand}"
                                    Background="{DynamicResource MetroTileSlateBrush}"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Click="RefocusBarcodeInput_Click"
                                    Content="Kapat" />
                        </DockPanel>

                        <ListBox Grid.Row="2"
                                 ItemsSource="{Binding CompletedReceipts}"
                                 Background="Transparent"
                                 BorderThickness="0">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,12" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Expander Background="Transparent"
                                              BorderThickness="0"
                                              IsExpanded="False">
                                        <Expander.Header>
                                            <Border Padding="18"
                                                    Background="{DynamicResource WindowBackgroundBrush}"
                                                    BorderBrush="{StaticResource BorderBrushDark}"
                                                    BorderThickness="1"
                                                    CornerRadius="18">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <TextBlock Text="{Binding ReceiptNo}"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   FontSize="19"
                                                                   FontWeight="Bold" />
                                                        <TextBlock Margin="0,6,0,0"
                                                                   Text="{Binding ItemCount, StringFormat={}{0} ürün}"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   FontSize="14" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Text="{Binding Date, StringFormat={}{0:dd.MM.yyyy HH:mm:ss}}"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   FontSize="13" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Text="{Binding PaidAmount, StringFormat=Ödenen: {0:0.00}}"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   FontSize="13" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:0.00}}"
                                                                   Foreground="{DynamicResource PrimaryBrush}"
                                                                   FontSize="28"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Right" />
                                                        <TextBlock Margin="0,6,0,0"
                                                                   Text="{Binding ChangeAmount, StringFormat=Para Üstü: {0:0.00}}"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   FontSize="13"
                                                                   HorizontalAlignment="Right" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </Expander.Header>

                                        <Border Margin="12,8,12,0"
                                                Padding="16"
                                                Background="{DynamicResource ShellUserPanelBackgroundBrush}"
                                                BorderBrush="{StaticResource BorderBrushDark}"
                                                BorderThickness="1"
                                                CornerRadius="16">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="14" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <ItemsControl ItemsSource="{Binding Items}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,0,0,10">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="80" />
                                                                    <ColumnDefinition Width="110" />
                                                                    <ColumnDefinition Width="120" />
                                                                </Grid.ColumnDefinitions>

                                                                <TextBlock Text="{Binding ProductName}"
                                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                                           FontSize="15"
                                                                           FontWeight="SemiBold" />
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding Quantity}"
                                                                           Foreground="{StaticResource TextMutedBrush}"
                                                                           FontSize="14"
                                                                           HorizontalAlignment="Center" />
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{Binding UnitPrice, StringFormat={}{0:0.00}}"
                                                                           Foreground="{StaticResource TextMutedBrush}"
                                                                           FontSize="14"
                                                                           HorizontalAlignment="Right" />
                                                                <TextBlock Grid.Column="3"
                                                                           Text="{Binding LineTotal, StringFormat={}{0:0.00}}"
                                                                           Foreground="{DynamicResource PrimaryBrush}"
                                                                           FontSize="15"
                                                                           FontWeight="Bold"
                                                                           HorizontalAlignment="Right" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <Grid Grid.Row="2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="14" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <Button Grid.Column="0"
                                                            Height="42"
                                                            Command="{Binding DataContext.PrintReceiptCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Background="{DynamicResource MetroTileSlateBrush}"
                                                            Foreground="White"
                                                            BorderThickness="0"
                                                            FontSize="15"
                                                            FontWeight="SemiBold"
                                                            Click="RefocusBarcodeInput_Click"
                                                            Content="Yazdır" />

                                                    <Button Grid.Column="2"
                                                            Height="42"
                                                            Command="{Binding DataContext.RestoreCompletedReceiptCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Background="{DynamicResource MetroTileTealBrush}"
                                                            Foreground="White"
                                                            BorderThickness="0"
                                                            FontSize="15"
                                                            FontWeight="SemiBold"
                                                            Click="RefocusBarcodeInput_Click"
                                                            Content="Tekrar Satışa Aktar" />
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </Expander>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>

