<UserControl x:Class="Bilnex.Pos.Views.PosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Loaded="UserControl_Loaded"
             d:DesignHeight="600"
             d:DesignWidth="1000">
    <Grid FocusManager.FocusedElement="{Binding ElementName=BarcodeTextBox}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="18" />
            <RowDefinition Height="118" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="7*" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.Column="0"
                Padding="22"
                Background="#111827"
                BorderBrush="{StaticResource BorderBrushDark}"
                BorderThickness="1"
                CornerRadius="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="Basket"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="30"
                                   FontWeight="Bold" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding ReceiptNo, StringFormat=Receipt: {0}}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="14" />
                    </StackPanel>

                    <Button DockPanel.Dock="Right"
                            Width="120"
                            Height="46"
                            Margin="16,0,0,0"
                            Command="{Binding DataContext.DashboardCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{StaticResource CompactNavButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72B;"
                                       Margin="0,0,8,0"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Geri"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </DockPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <TextBox x:Name="BarcodeTextBox"
                                 Height="48"
                                 Padding="14,10"
                                 Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="20"
                                 Background="#0B1220"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource BorderBrushDark}"
                                 BorderThickness="1"
                                 Focusable="True"
                                 VerticalContentAlignment="Center"
                                 PreviewTextInput="BarcodeTextBox_PreviewTextInput"
                                 PreviewKeyDown="BarcodeTextBox_PreviewKeyDown" />
                        <TextBlock Margin="16,0,0,0"
                                   Text="Barkod okut veya kod gir"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="16"
                                   IsHitTestVisible="False"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Barcode}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Barcode}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                    </Grid>

                    <Button Grid.Column="2"
                            Width="150"
                            Height="48"
                            Command="{Binding AddProductCommand}"
                            Background="#1B2A43"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Click="RefocusBarcodeInput_Click"
                            Content="Scan Barcode" />
                </Grid>

                <Border Grid.Row="4"
                        Padding="14,12"
                        Background="#0B1220"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10"
                                     Height="10"
                                     Margin="0,0,10,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#64748B" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsScannerInputActive}" Value="True">
                                                <Setter Property="Fill" Value="#22C55E" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding ScannerStatusText}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding LastScannedProduct}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="14"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Grid.Row="5"
                        Padding="12,10"
                        Background="#3F1D1D"
                        BorderBrush="#7F1D1D"
                        BorderThickness="1"
                        CornerRadius="14">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LastInvalidBarcode}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding LastInvalidBarcode}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding LastInvalidBarcode}"
                               Foreground="#FECACA"
                               FontSize="13"
                               FontWeight="SemiBold" />
                </Border>

                <DataGrid Grid.Row="6"
                          ItemsSource="{Binding BasketItems}"
                          SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          HeadersVisibility="Column"
                          IsReadOnly="True"
                          GridLinesVisibility="None"
                          RowHeaderWidth="0"
                          Background="#0B1220"
                          BorderBrush="{StaticResource BorderBrushDark}"
                          BorderThickness="1"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          FontSize="18">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#131D31" />
                            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                            <Setter Property="FontSize" Value="14" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="BorderBrush" Value="#233148" />
                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                            <Setter Property="Padding" Value="14,12" />
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Background" Value="#0B1220" />
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="14,12" />
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="#0B1220" />
                            <Setter Property="BorderBrush" Value="#1E293B" />
                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLastAdded}" Value="True">
                                    <Setter Property="Background" Value="#163523" />
                                </DataTrigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#1D4ED8" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Product"
                                            Binding="{Binding ProductName}"
                                            Width="*" />
                        <DataGridTemplateColumn Header="Qty"
                                                Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="36" />
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0"
                                                Width="28"
                                                Height="28"
                                                Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Background="#3A2A1E"
                                                Foreground="White"
                                                BorderThickness="0"
                                                FontSize="16"
                                                FontWeight="Bold"
                                                Click="RefocusBarcodeInput_Click"
                                                Content="-" />

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Quantity}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />

                                        <Button Grid.Column="2"
                                                Width="28"
                                                Height="28"
                                                Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Background="#1E3A2A"
                                                Foreground="White"
                                                BorderThickness="0"
                                                FontSize="16"
                                                FontWeight="Bold"
                                                Click="RefocusBarcodeInput_Click"
                                                Content="+" />
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Price"
                                            Binding="{Binding UnitPrice, StringFormat={}{0:0.00}}"
                                            Width="140" />
                        <DataGridTextColumn Header="Total"
                                            Binding="{Binding LineTotal, StringFormat={}{0:0.00}}"
                                            Width="160" />
                        <DataGridTemplateColumn Header="Actions"
                                                Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Width="86"
                                            Height="34"
                                            Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Background="#4B1F2F"
                                            Foreground="White"
                                            BorderThickness="0"
                                            FontSize="14"
                                            Click="RefocusBarcodeInput_Click"
                                            Content="Delete" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="0"
                Grid.Column="2"
                Padding="20"
                Background="#0F172A"
                BorderBrush="{StaticResource BorderBrushDark}"
                BorderThickness="1"
                CornerRadius="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="220" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Quick Products"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="26"
                               FontWeight="Bold" />
                    <TextBlock Margin="0,6,0,0"
                               Text="Tap to add product"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="14" />
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Height="44"
                                Command="{Binding SuspendSaleCommand}"
                                Background="#7C2D12"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Click="RefocusBarcodeInput_Click"
                                Content="Askıya Al" />

                        <Button Grid.Column="2"
                                Height="44"
                                Command="{Binding OpenHeldSalesCommand}"
                                Background="#334155"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Click="RefocusBarcodeInput_Click"
                                Content="Askı Listesi" />
                        <Button Grid.Column="4"
                                Height="44"
                                Command="{Binding OpenReceiptHistoryCommand}"
                                Background="#0F766E"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Click="RefocusBarcodeInput_Click"
                                Content="Fis Gecmisi" />
                    </Grid>

                    <ItemsControl Grid.Row="2"
                              ItemsSource="{Binding QuickProducts}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="0,0,12,12"
                                        Padding="16"
                                        Background="#162033"
                                        BorderBrush="#27344A"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        Command="{Binding DataContext.AddProductCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Click="RefocusBarcodeInput_Click"
                                        CommandParameter="{Binding Name}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="RootBorder"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="16">
                                                <Grid Margin="{TemplateBinding Padding}">
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               FontSize="20"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="RootBorder" Property="Background" Value="#1B2A43" />
                                                    <Setter TargetName="RootBorder" Property="BorderBrush" Value="#3B82F6" />
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="RootBorder" Property="RenderTransform">
                                                        <Setter.Value>
                                                            <ScaleTransform ScaleX="0.98" ScaleY="0.98" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

                <Border Grid.Row="4"
                        Padding="16"
                        Background="#111827"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Barcode History"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="20"
                                       FontWeight="SemiBold" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="Recent scans"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="13" />
                        </StackPanel>

                        <ListBox Grid.Row="2"
                                 ItemsSource="{Binding BarcodeHistory}"
                                 Background="Transparent"
                                 BorderThickness="0">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,8" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12"
                                            Background="#0B1220"
                                            CornerRadius="12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="{Binding ProductName}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="15"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Margin="0,2,0,0"
                                                           Text="{Binding Barcode}"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="12" />
                                            </StackPanel>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding TimeText}"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Padding="18"
                Background="#0B1220"
                BorderBrush="{StaticResource BorderBrushDark}"
                BorderThickness="1"
                CornerRadius="24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="24,14"
                        Background="#162033"
                        CornerRadius="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="TOTAL AMOUNT"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding ItemCount}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="17" />
                        </StackPanel>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding TotalAmount, StringFormat={}{0:0.00}}"
                                   Foreground="#A5F3C6"
                                   FontSize="42"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <ItemsControl Grid.Column="2"
                              Grid.ColumnSpan="3"
                              ItemsSource="{Binding PaymentMethods}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1" Columns="2" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="0,0,18,0"
                                    Height="80"
                                    Command="{Binding DataContext.OpenPaymentMethodCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding Key}"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    FontSize="28"
                                    FontWeight="Bold"
                                    Click="RefocusBarcodeInput_Click"
                                    Content="{Binding Title}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#334155" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Key}" Value="Cash">
                                                <Setter Property="Background" Value="#1E3A2A" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Key}" Value="Card">
                                                <Setter Property="Background" Value="#1E2F4D" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Grid.Column="6"
                        Content="Odeme Al"
                        FontSize="26"
                        FontWeight="Bold"
                        Background="#0F766E"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Height="80"
                        Click="RefocusBarcodeInput_Click"
                        Command="{Binding ReceivePaymentCommand}" />
            </Grid>
        </Border>

        <Border Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Background="#AA020617">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPaymentScreenOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid>
                <Border Width="560"
                        Padding="28"
                        Background="#111827"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="26"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Odeme Al"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="30"
                                           FontWeight="Bold" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding PaymentMethod}"
                                           Foreground="#A5F3C6"
                                           FontSize="16"
                                           FontWeight="SemiBold" />
                            </StackPanel>

                            <Button DockPanel.Dock="Right"
                                    Width="120"
                                    Height="42"
                                    Command="{Binding CancelPaymentCommand}"
                                    Background="#3A2A1E"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Content="Vazgec" />
                        </DockPanel>

                        <Border Grid.Row="2"
                                Padding="18"
                                Background="#0B1220"
                                CornerRadius="18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Odenecek Tutar"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="14" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding ItemCount}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="15" />
                                </StackPanel>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding TotalAmount, StringFormat={}{0:0.00}}"
                                           Foreground="#A5F3C6"
                                           FontSize="40"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="4">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCashPayment}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Alinan Tutar"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="16"
                                       FontWeight="SemiBold" />

                            <TextBox Grid.Row="2"
                                     Height="50"
                                     Padding="14,10"
                                     Text="{Binding ReceivedAmountText, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="22"
                                     Background="#0B1220"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderBrush="{StaticResource BorderBrushDark}"
                                     BorderThickness="1"
                                     VerticalContentAlignment="Center" />

                            <ItemsControl Grid.Row="4"
                                          ItemsSource="{Binding QuickAmounts}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="3" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Margin="0,0,10,10"
                                                Height="42"
                                                Command="{Binding DataContext.SetQuickReceivedAmountCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Value}"
                                                Foreground="White"
                                                BorderThickness="0"
                                                FontSize="15"
                                                FontWeight="SemiBold"
                                                Content="{Binding Title}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="#334155" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Value}" Value="TOTAL">
                                                            <Setter Property="Background" Value="#0F766E" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <Border Grid.Row="6"
                                Padding="18"
                                Background="#162033"
                                CornerRadius="18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Para Ustu"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="14" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding ChangeAmountText}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="28"
                                               FontWeight="Bold" />
                                </StackPanel>

                                <ItemsControl Grid.Column="1"
                                              Grid.ColumnSpan="3"
                                              ItemsSource="{Binding PaymentMethods}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="1" Columns="2" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Margin="0,0,18,0"
                                                    Height="52"
                                                    Command="{Binding DataContext.SelectPaymentMethodCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Key}"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    FontSize="20"
                                                    FontWeight="Bold"
                                                    Content="{Binding Title}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="#334155" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Key}" Value="Cash">
                                                                <Setter Property="Background" Value="#1E3A2A" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Key}" Value="Card">
                                                                <Setter Property="Background" Value="#1E2F4D" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button Grid.Column="5"
                                        Width="150"
                                        Height="52"
                                        Command="{Binding CompletePaymentCommand}"
                                        Background="#0F766E"
                                        Foreground="White"
                                        BorderThickness="0"
                                        FontSize="20"
                                        FontWeight="Bold"
                                        Content="Onayla" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Background="#AA020617">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsHeldSalesScreenOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid>
                <Border Width="720"
                        Padding="28"
                        Background="#111827"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="26"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Askıdaki Fisler"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="30"
                                           FontWeight="Bold" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding HeldSalesCountText}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="15" />
                            </StackPanel>

                            <Button DockPanel.Dock="Right"
                                    Width="120"
                                    Height="42"
                                    Command="{Binding CloseHeldSalesCommand}"
                                    Background="#3A2A1E"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Click="RefocusBarcodeInput_Click"
                                    Content="Kapat" />
                        </DockPanel>

                        <ListBox Grid.Row="2"
                                 ItemsSource="{Binding HeldSales}"
                                 Background="Transparent"
                                 BorderThickness="0">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,12" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="18"
                                            Background="#0B1220"
                                            BorderBrush="{StaticResource BorderBrushDark}"
                                            BorderThickness="1"
                                            CornerRadius="18">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="18" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="{Binding ReferenceNo}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="19"
                                                           FontWeight="Bold" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="{Binding ItemCount, StringFormat={}{0} urun}"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="14" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Text="{Binding TimeText}"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="13" />
                                            </StackPanel>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding TotalAmount, StringFormat={}{0:0.00}}"
                                                       Foreground="#A5F3C6"
                                                       FontSize="28"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center" />

                                            <Button Grid.Column="3"
                                                    Width="160"
                                                    Height="46"
                                                    Command="{Binding DataContext.RecallHeldSaleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="#0F766E"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    FontSize="18"
                                                    FontWeight="SemiBold"
                                                    Click="RefocusBarcodeInput_Click"
                                                    Content="Geri Cagir" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Background="#AA020617">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsReceiptHistoryScreenOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid>
                <Border Width="760"
                        Padding="28"
                        Background="#111827"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="26"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Tamamlanan Fisler"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="30"
                                           FontWeight="Bold" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding CompletedReceiptsCountText}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="15" />
                            </StackPanel>

                            <Button DockPanel.Dock="Right"
                                    Width="120"
                                    Height="42"
                                    Command="{Binding CloseReceiptHistoryCommand}"
                                    Background="#3A2A1E"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Click="RefocusBarcodeInput_Click"
                                    Content="Kapat" />
                        </DockPanel>

                        <ListBox Grid.Row="2"
                                 ItemsSource="{Binding CompletedReceipts}"
                                 Background="Transparent"
                                 BorderThickness="0">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,12" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Expander Background="Transparent"
                                              BorderThickness="0"
                                              IsExpanded="False">
                                        <Expander.Header>
                                            <Border Padding="18"
                                                    Background="#0B1220"
                                                    BorderBrush="{StaticResource BorderBrushDark}"
                                                    BorderThickness="1"
                                                    CornerRadius="18">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <TextBlock Text="{Binding ReceiptNo}"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   FontSize="19"
                                                                   FontWeight="Bold" />
                                                        <TextBlock Margin="0,6,0,0"
                                                                   Text="{Binding ItemCount, StringFormat={}{0} urun}"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   FontSize="14" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Text="{Binding Date, StringFormat={}{0:dd.MM.yyyy HH:mm:ss}}"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   FontSize="13" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Text="{Binding PaidAmount, StringFormat=Odenen: {0:0.00}}"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   FontSize="13" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:0.00}}"
                                                                   Foreground="#A5F3C6"
                                                                   FontSize="28"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Right" />
                                                        <TextBlock Margin="0,6,0,0"
                                                                   Text="{Binding ChangeAmount, StringFormat=Para Ustu: {0:0.00}}"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   FontSize="13"
                                                                   HorizontalAlignment="Right" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </Expander.Header>

                                        <Border Margin="12,8,12,0"
                                                Padding="16"
                                                Background="#111827"
                                                BorderBrush="{StaticResource BorderBrushDark}"
                                                BorderThickness="1"
                                                CornerRadius="16">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="14" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <ItemsControl ItemsSource="{Binding Items}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,0,0,10">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="80" />
                                                                    <ColumnDefinition Width="110" />
                                                                    <ColumnDefinition Width="120" />
                                                                </Grid.ColumnDefinitions>

                                                                <TextBlock Text="{Binding ProductName}"
                                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                                           FontSize="15"
                                                                           FontWeight="SemiBold" />
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding Quantity}"
                                                                           Foreground="{StaticResource TextMutedBrush}"
                                                                           FontSize="14"
                                                                           HorizontalAlignment="Center" />
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{Binding UnitPrice, StringFormat={}{0:0.00}}"
                                                                           Foreground="{StaticResource TextMutedBrush}"
                                                                           FontSize="14"
                                                                           HorizontalAlignment="Right" />
                                                                <TextBlock Grid.Column="3"
                                                                           Text="{Binding LineTotal, StringFormat={}{0:0.00}}"
                                                                           Foreground="#A5F3C6"
                                                                           FontSize="15"
                                                                           FontWeight="Bold"
                                                                           HorizontalAlignment="Right" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <Grid Grid.Row="2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="14" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <Button Grid.Column="0"
                                                            Height="42"
                                                            Command="{Binding DataContext.PrintReceiptCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Background="#334155"
                                                            Foreground="White"
                                                            BorderThickness="0"
                                                            FontSize="15"
                                                            FontWeight="SemiBold"
                                                            Click="RefocusBarcodeInput_Click"
                                                            Content="Yazdir" />

                                                    <Button Grid.Column="2"
                                                            Height="42"
                                                            Command="{Binding DataContext.RestoreCompletedReceiptCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Background="#0F766E"
                                                            Foreground="White"
                                                            BorderThickness="0"
                                                            FontSize="15"
                                                            FontWeight="SemiBold"
                                                            Click="RefocusBarcodeInput_Click"
                                                            Content="Tekrar Satisa Aktar" />
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </Expander>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
