<UserControl x:Class="Bilnex.Pos.Views.ProjectSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="1000">
    <Border Padding="28"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrushDark}"
            BorderThickness="1"
            CornerRadius="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Project Settings"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="32"
                               FontWeight="Bold" />
                    <TextBlock Margin="0,8,0,0"
                               Text="POS hizli odeme tutarlarini yonetin"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="14" />
                </StackPanel>

                <Button DockPanel.Dock="Right"
                        Width="120"
                        Height="42"
                        Margin="24,0,0,0"
                        Command="{Binding DataContext.DashboardCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        Style="{StaticResource TileButtonStyle}"
                        Content="Back" />
            </DockPanel>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Border Padding="24"
                        Background="#111827"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="28" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="28" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Quick Amounts"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="24"
                                   FontWeight="SemiBold" />

                        <TextBlock Grid.Row="2"
                                   Text="Virgul ile ayirarak girin. Ornek: 50, 100, 200, 500, 1000"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="14"
                                   TextWrapping="Wrap" />

                        <TextBox Grid.Row="4"
                                 Height="48"
                                 Padding="14,10"
                                 Text="{Binding QuickAmountsText, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="20"
                                 Background="#0B1220"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource BorderBrushDark}"
                                 BorderThickness="1"
                                 VerticalContentAlignment="Center" />

                        <StackPanel Grid.Row="6"
                                    Orientation="Horizontal">
                            <Button Width="160"
                                    Height="46"
                                    Command="{Binding SaveQuickAmountsCommand}"
                                    Background="#0F766E"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="17"
                                    FontWeight="SemiBold"
                                    Content="Kaydet" />

                            <Button Width="160"
                                    Height="46"
                                    Margin="12,0,0,0"
                                    Command="{Binding ResetQuickAmountsCommand}"
                                    Background="#334155"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="17"
                                    FontWeight="SemiBold"
                                    Content="Varsayilan" />
                        </StackPanel>

                        <TextBlock Grid.Row="8"
                                   Text="Payment Methods"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="24"
                                   FontWeight="SemiBold" />

                        <TextBlock Grid.Row="10"
                                   Text="Desteklenen tipler: Cash, Card. Ornek: Cash, Card"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="14"
                                   TextWrapping="Wrap" />

                        <StackPanel Grid.Row="12">
                            <TextBox Height="48"
                                     Padding="14,10"
                                     Text="{Binding PaymentMethodsText, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="20"
                                     Background="#0B1220"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderBrush="{StaticResource BorderBrushDark}"
                                     BorderThickness="1"
                                     VerticalContentAlignment="Center" />

                            <StackPanel Orientation="Horizontal"
                                        Margin="0,18,0,0">
                                <Button Width="160"
                                        Height="46"
                                        Command="{Binding SavePaymentMethodsCommand}"
                                        Background="#0F766E"
                                        Foreground="White"
                                        BorderThickness="0"
                                        FontSize="17"
                                        FontWeight="SemiBold"
                                        Content="Kaydet" />

                                <Button Width="160"
                                        Height="46"
                                        Margin="12,0,0,0"
                                        Command="{Binding ResetPaymentMethodsCommand}"
                                        Background="#334155"
                                        Foreground="White"
                                        BorderThickness="0"
                                        FontSize="17"
                                        FontWeight="SemiBold"
                                        Content="Varsayilan" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Grid.Row="14"
                                   Text="General Settings"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="24"
                                   FontWeight="SemiBold" />

                        <TextBlock Grid.Row="16"
                                   Text="Varsayilan odeme tipi"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="14" />

                        <TextBox Grid.Row="18"
                                 Height="48"
                                 Padding="14,10"
                                 Text="{Binding DefaultPaymentMethod, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="20"
                                 Background="#0B1220"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource BorderBrushDark}"
                                 BorderThickness="1"
                                 VerticalContentAlignment="Center" />

                        <TextBlock Grid.Row="20"
                                   Text="Tema (Dark veya Light)"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="14" />

                        <TextBox Grid.Row="22"
                                 Height="48"
                                 Padding="14,10"
                                 Text="{Binding Theme, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="20"
                                 Background="#0B1220"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource BorderBrushDark}"
                                 BorderThickness="1"
                                 VerticalContentAlignment="Center" />

                        <TextBlock Grid.Row="24"
                                   Text="Fis yazici adi"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="14" />

                        <TextBox Grid.Row="26"
                                 Height="48"
                                 Padding="14,10"
                                 Text="{Binding ReceiptPrinterName, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="20"
                                 Background="#0B1220"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource BorderBrushDark}"
                                 BorderThickness="1"
                                 VerticalContentAlignment="Center" />

                        <StackPanel Grid.Row="28"
                                    Orientation="Horizontal">
                            <Button Width="160"
                                    Height="46"
                                    Command="{Binding SaveGeneralSettingsCommand}"
                                    Background="#0F766E"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="17"
                                    FontWeight="SemiBold"
                                    Content="Kaydet" />

                            <Button Width="160"
                                    Height="46"
                                    Margin="12,0,0,0"
                                    Command="{Binding ResetGeneralSettingsCommand}"
                                    Background="#334155"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="17"
                                    FontWeight="SemiBold"
                                    Content="Varsayilan" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Padding="24"
                        Background="#0F172A"
                        BorderBrush="{StaticResource BorderBrushDark}"
                        BorderThickness="1"
                        CornerRadius="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Current Setup"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="22"
                                   FontWeight="SemiBold" />

                        <Grid Grid.Row="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="20" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Quick Amount Buttons"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold" />

                            <ItemsControl Grid.Row="2"
                                          ItemsSource="{Binding QuickAmounts}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,12,12"
                                                Padding="16"
                                                Background="#162033"
                                                BorderBrush="#27344A"
                                                BorderThickness="1"
                                                CornerRadius="16">
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Grid.Row="4"
                                       Text="Payment Buttons"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold" />

                            <ItemsControl Grid.Row="6"
                                          ItemsSource="{Binding PaymentMethods}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,12,12"
                                                Padding="16"
                                                Background="#162033"
                                                BorderBrush="#27344A"
                                                BorderThickness="1"
                                                CornerRadius="16">
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <Border Grid.Row="4"
                                Padding="14,12"
                                Background="#0B1220"
                                CornerRadius="14">
                            <TextBlock Text="{Binding StatusMessage}"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="13"
                                       TextWrapping="Wrap" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
