                                                <TextBlock Text="&#x2190; Sol"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="Sepet (&#xFC;r&#xFC;n listesi) ekran&#x131;n sol taraf&#x131;nda yer al&#x131;r."
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </RadioButton>
                                    </Border>

