<UserControl x:Class="Bilnex.Pos.Views.ProjectSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="1000">
    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto"
                  CanContentScroll="False">
    <Border MinWidth="920"
            MinHeight="620"
            Padding="28"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrushDark}"
            BorderThickness="1"
            CornerRadius="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Proje Ayarları"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="32"
                               FontWeight="Bold" />
                    <TextBlock Margin="0,8,0,0"
                               Text="POS ayarlarını kategori bazlı olarak yönetin"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="14" />
                </StackPanel>

                <Button DockPanel.Dock="Right"
                        Width="120"
                        Height="42"
                        Margin="24,0,0,0"
                        Command="{Binding DataContext.DashboardCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        Style="{StaticResource CompactNavButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72B;"
                                   Margin="0,0,8,0"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="13"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Geri"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </DockPanel>

            <TabControl Grid.Row="2"
                        Background="Transparent"
                        BorderThickness="0"
                        TabStripPlacement="Left">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                        <Setter Property="FontSize" Value="15" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Width" Value="220" />
                        <Setter Property="Height" Value="72" />
                        <Setter Property="Margin" Value="0,0,14,10" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="RootBorder"
                                            Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{StaticResource BorderBrushDark}"
                                            BorderThickness="1"
                                            CornerRadius="16">
                                        <ContentPresenter Margin="18,14"
                                                          HorizontalAlignment="Left"
                                                          VerticalAlignment="Center"
                                                          ContentSource="Header" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                                            <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrushHover}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE1D3;"
                                           Margin="0,0,10,0"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Hızlı Tutarlar"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Margin="26,6,0,0" Text="Nakit butonları" FontSize="12" Opacity="0.8" />
                        </StackPanel>
                    </TabItem.Header>
                    <Grid Margin="8,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <Border Padding="24" Background="{DynamicResource ShellContentBackgroundBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="18" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="18" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Hızlı Tutar Ayarları" Foreground="{StaticResource TextPrimaryBrush}" FontSize="24" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="2" Text="Virgül ile ayırarak girin. Örnek: 50, 100, 200, 500, 1000" Foreground="{StaticResource TextMutedBrush}" FontSize="14" TextWrapping="Wrap" />
                                <TextBox Grid.Row="4" Height="48" Padding="14,10" Text="{Binding QuickAmountsText, UpdateSourceTrigger=PropertyChanged}" FontSize="20" Background="{DynamicResource WindowBackgroundBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" VerticalContentAlignment="Center" />
                                <StackPanel Grid.Row="6" Orientation="Horizontal">
                                    <Button Width="160" Height="46" Command="{Binding SaveQuickAmountsCommand}" FontSize="17" FontWeight="SemiBold" Style="{StaticResource PrimaryActionButtonStyle}" ><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE74E;" Margin="0,0,8,0" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" /><TextBlock Text="Kaydet" VerticalAlignment="Center" /></StackPanel></Button>
                                    <Button Width="160" Height="46" Margin="12,0,0,0" Command="{Binding ResetQuickAmountsCommand}" FontSize="17" FontWeight="SemiBold" Style="{StaticResource SecondaryActionButtonStyle}" ><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE777;" Margin="0,0,8,0" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" /><TextBlock Text="Varsayılan" VerticalAlignment="Center" /></StackPanel></Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Column="2" Padding="24" Background="{DynamicResource ShellUserPanelBackgroundBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="14" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="18" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Mevcut Tutar Butonları" Foreground="{StaticResource TextPrimaryBrush}" FontSize="22" FontWeight="SemiBold" />
                                <ItemsControl Grid.Row="2" ItemsSource="{Binding QuickAmounts}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="2" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,12,12" Padding="16" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="16">
                                                <TextBlock Text="{Binding Title}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border Grid.Row="4" Padding="14,12" Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="14">
                                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextMutedBrush}" FontSize="13" TextWrapping="Wrap" />
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8C7;"
                                           Margin="0,0,10,0"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Ödeme Yöntemleri"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Margin="26,6,0,0" Text="Nakit ve kart" FontSize="12" Opacity="0.8" />
                        </StackPanel>
                    </TabItem.Header>
                    <Grid Margin="8,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <Border Padding="24" Background="{DynamicResource ShellContentBackgroundBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="18" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="18" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Ödeme Tipleri" Foreground="{StaticResource TextPrimaryBrush}" FontSize="24" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="2" Text="Desteklenen tipler: Nakit, Kart. Örnek: Nakit, Kart" Foreground="{StaticResource TextMutedBrush}" FontSize="14" TextWrapping="Wrap" />
                                <TextBox Grid.Row="4" Height="48" Padding="14,10" Text="{Binding PaymentMethodsText, UpdateSourceTrigger=PropertyChanged}" FontSize="20" Background="{DynamicResource WindowBackgroundBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" VerticalContentAlignment="Center" />
                                <StackPanel Grid.Row="6" Orientation="Horizontal">
                                    <Button Width="160" Height="46" Command="{Binding SavePaymentMethodsCommand}" FontSize="17" FontWeight="SemiBold" Style="{StaticResource PrimaryActionButtonStyle}" ><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE74E;" Margin="0,0,8,0" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" /><TextBlock Text="Kaydet" VerticalAlignment="Center" /></StackPanel></Button>
                                    <Button Width="160" Height="46" Margin="12,0,0,0" Command="{Binding ResetPaymentMethodsCommand}" FontSize="17" FontWeight="SemiBold" Style="{StaticResource SecondaryActionButtonStyle}" ><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE777;" Margin="0,0,8,0" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" /><TextBlock Text="Varsayılan" VerticalAlignment="Center" /></StackPanel></Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Column="2" Padding="24" Background="{DynamicResource ShellUserPanelBackgroundBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="14" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="18" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Aktif Ödeme Butonları" Foreground="{StaticResource TextPrimaryBrush}" FontSize="22" FontWeight="SemiBold" />
                                <ItemsControl Grid.Row="2" ItemsSource="{Binding PaymentMethods}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="2" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,12,12" Padding="16" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="16">
                                                <TextBlock Text="{Binding Title}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border Grid.Row="4" Padding="14,12" Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="14">
                                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextMutedBrush}" FontSize="13" TextWrapping="Wrap" />
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE713;"
                                           Margin="0,0,10,0"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Genel Ayarlar"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Margin="26,6,0,0" Text="Tema ve cihaz" FontSize="12" Opacity="0.8" />
                        </StackPanel>
                    </TabItem.Header>
                    <Grid Margin="8,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <Border Padding="24" Background="{DynamicResource ShellContentBackgroundBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="18" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="18" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="18" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Genel POS Ayarları" Foreground="{StaticResource TextPrimaryBrush}" FontSize="24" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="2" Text="Varsayılan ödeme tipi" Foreground="{StaticResource TextMutedBrush}" FontSize="14" />
                                <ComboBox Grid.Row="4" Height="48" Padding="10,6" ItemsSource="{Binding DefaultPaymentMethodOptions}" DisplayMemberPath="Title" SelectedValuePath="Key" SelectedValue="{Binding DefaultPaymentMethod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="18" Background="{DynamicResource WindowBackgroundBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" VerticalContentAlignment="Center" />
                                <TextBlock Grid.Row="6" Text="Tema seçimi" Foreground="{StaticResource TextMutedBrush}" FontSize="14" />
                                <ComboBox Grid.Row="8" Height="48" Padding="10,6" ItemsSource="{Binding ThemeOptions}" DisplayMemberPath="Title" SelectedValuePath="Key" SelectedValue="{Binding Theme, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="18" Background="{DynamicResource WindowBackgroundBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" VerticalContentAlignment="Center" />
                                <TextBlock Grid.Row="10" Text="Fiş yazıcı adı" Foreground="{StaticResource TextMutedBrush}" FontSize="14" />
                                <TextBox Grid.Row="12" Height="48" Padding="14,10" Text="{Binding ReceiptPrinterName, UpdateSourceTrigger=PropertyChanged}" FontSize="20" Background="{DynamicResource WindowBackgroundBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" VerticalContentAlignment="Center" />
                                <StackPanel Grid.Row="14" Orientation="Horizontal">
                                    <Button Width="160" Height="46" Command="{Binding SaveGeneralSettingsCommand}" FontSize="17" FontWeight="SemiBold" Style="{StaticResource PrimaryActionButtonStyle}" ><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE74E;" Margin="0,0,8,0" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" /><TextBlock Text="Kaydet" VerticalAlignment="Center" /></StackPanel></Button>
                                    <Button Width="160" Height="46" Margin="12,0,0,0" Command="{Binding ResetGeneralSettingsCommand}" FontSize="17" FontWeight="SemiBold" Style="{StaticResource SecondaryActionButtonStyle}" ><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE777;" Margin="0,0,8,0" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" /><TextBlock Text="Varsayılan" VerticalAlignment="Center" /></StackPanel></Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Column="2" Padding="24" Background="{DynamicResource ShellUserPanelBackgroundBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="18" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="18" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Anlık Özet" Foreground="{StaticResource TextPrimaryBrush}" FontSize="22" FontWeight="SemiBold" />
                                <Border Grid.Row="2" Padding="16" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="16">
                                    <StackPanel>
                                        <TextBlock Text="Varsayılan Ödeme" Foreground="{StaticResource TextMutedBrush}" FontSize="13" />
                                        <TextBlock Margin="0,6,0,0" Text="{Binding DefaultPaymentMethodDisplay}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="20" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="4" Padding="16" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="16">
                                    <StackPanel>
                                        <TextBlock Text="Tema" Foreground="{StaticResource TextMutedBrush}" FontSize="13" />
                                        <TextBlock Margin="0,6,0,0" Text="{Binding ThemeDisplay}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="20" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="6" Padding="16" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="16">
                                    <StackPanel>
                                        <TextBlock Text="Fiş Yazıcı" Foreground="{StaticResource TextMutedBrush}" FontSize="13" />
                                        <TextBlock Margin="0,6,0,0" Text="{Binding ReceiptPrinterName}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="8" Padding="14,12" Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="14" VerticalAlignment="Bottom">
                                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextMutedBrush}" FontSize="13" TextWrapping="Wrap" />
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8AB;"
                                           Margin="0,0,10,0"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Fiyat Değişimi"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Margin="26,6,0,0" Text="Fiyat güncelleme" FontSize="12" Opacity="0.8" />
                        </StackPanel>
                    </TabItem.Header>
                    <Grid Margin="8,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <Border Padding="24" Background="{DynamicResource ShellContentBackgroundBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="18" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="18" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Fiyat Değişimi Ayarları" Foreground="{StaticResource TextPrimaryBrush}" FontSize="24" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="2"
                                           Text="Fiyat değişim tipi ve uygulanacak değeri belirleyin."
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="14"
                                           TextWrapping="Wrap" />
                                <TextBlock Grid.Row="4" Text="Değişim tipi" Foreground="{StaticResource TextMutedBrush}" FontSize="14" />
                                <ComboBox Grid.Row="6"
                                          Height="48"
                                          Padding="10,6"
                                          ItemsSource="{Binding PriceChangeModeOptions}"
                                          DisplayMemberPath="Title"
                                          SelectedValuePath="Key"
                                          SelectedValue="{Binding PriceChangeMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          FontSize="18"
                                          Background="{DynamicResource WindowBackgroundBrush}"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          BorderBrush="{StaticResource BorderBrushDark}"
                                          BorderThickness="1"
                                          VerticalContentAlignment="Center" />
                                <Grid Grid.Row="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.1*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="0.9*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Değer"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="14" />
                                        <TextBox Margin="0,12,0,0"
                                                 Height="48"
                                                 Padding="14,10"
                                                 Text="{Binding PriceChangeValue, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="18"
                                                 Background="{DynamicResource WindowBackgroundBrush}"
                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                 BorderBrush="{StaticResource BorderBrushDark}"
                                                 BorderThickness="1"
                                                 VerticalContentAlignment="Center" />
                                    </StackPanel>
                                    <CheckBox Grid.Column="2"
                                              Content="Onay zorunlu olsun"
                                              IsChecked="{Binding RequirePriceApproval, Mode=TwoWay}"
                                              Foreground="{StaticResource TextPrimaryBrush}"
                                              FontSize="16"
                                              FontWeight="SemiBold"
                                              VerticalAlignment="Center" />
                                </Grid>
                                <StackPanel Grid.Row="10" Orientation="Horizontal">
                                    <Button Width="160"
                                            Height="46"
                                            Command="{Binding SavePriceChangeSettingsCommand}"
                                            FontSize="17"
                                            FontWeight="SemiBold"
                                            Style="{StaticResource PrimaryActionButtonStyle}"
                                            ><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE74E;" Margin="0,0,8,0" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" /><TextBlock Text="Kaydet" VerticalAlignment="Center" /></StackPanel></Button>
                                    <Button Width="160"
                                            Height="46"
                                            Margin="12,0,0,0"
                                            Command="{Binding ResetPriceChangeSettingsCommand}"
                                            FontSize="17"
                                            FontWeight="SemiBold"
                                            Style="{StaticResource SecondaryActionButtonStyle}"
                                            ><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE777;" Margin="0,0,8,0" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" /><TextBlock Text="Varsayılan" VerticalAlignment="Center" /></StackPanel></Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Column="2" Padding="24" Background="{DynamicResource ShellUserPanelBackgroundBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="20">
                            <StackPanel>
                                <TextBlock Text="Anlık Özet" Foreground="{StaticResource TextPrimaryBrush}" FontSize="22" FontWeight="SemiBold" />
                                <Border Margin="0,18,0,0" Padding="16" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="16">
                                    <StackPanel>
                                        <TextBlock Text="Değişim Tipi" Foreground="{StaticResource TextMutedBrush}" FontSize="13" />
                                        <TextBlock Margin="0,6,0,0" Text="{Binding PriceChangeModeDisplay}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="20" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,12,0,0" Padding="16" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="16">
                                    <StackPanel>
                                        <TextBlock Text="Değer" Foreground="{StaticResource TextMutedBrush}" FontSize="13" />
                                        <TextBlock Margin="0,6,0,0" Text="{Binding PriceChangeValue}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="20" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,12,0,0" Padding="16" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="16">
                                    <StackPanel>
                                        <TextBlock Text="Onay Akışı" Foreground="{StaticResource TextMutedBrush}" FontSize="13" />
                                        <TextBlock Margin="0,6,0,0" Text="{Binding RequirePriceApproval}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="20" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,18,0,0" Padding="14,12" Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="14">
                                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextMutedBrush}" FontSize="13" TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem>
                    <TabItem.Header>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE749;"
                                           Margin="0,0,10,0"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Etiket Basımı"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Margin="26,6,0,0" Text="Etiket ve raf çıktıları" FontSize="12" Opacity="0.8" />
                        </StackPanel>
                    </TabItem.Header>
