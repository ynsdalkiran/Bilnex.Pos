                                            BorderThickness="2"
                                            Padding="14,12"
                                            Cursor="Hand">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBasketRight}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                                        <Setter Property="Background" Value="{DynamicResource ShellUserPanelBackgroundBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <RadioButton IsChecked="{Binding IsBasketRight, Mode=TwoWay}"
                                                     GroupName="BasketPosition"
                                                     Cursor="Hand"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     FocusVisualStyle="{x:Null}">
                                            <StackPanel>
                                                <TextBlock Text="Sa&#x11F; &#x2192;"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="Sepet ekran&#x131;n sa&#x11F; taraf&#x131;na ta&#x15F;&#x131;n&#x131;r, &#xFC;r&#xFC;nler solda kal&#x131;r."
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </RadioButton>
                                    </Border>
                                </UniformGrid>

                                <!-- Butonlar -->
                                <Grid Margin="0,28,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Height="46"
                                            Content="Varsay&#x131;lana S&#x131;f&#x131;rla"
                                            FontSize="14"
                                            Command="{Binding ResetPosLayoutCommand}"
                                            Background="{DynamicResource WindowBackgroundBrush}"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            BorderBrush="{StaticResource BorderBrushDark}"
                                            BorderThickness="1"
                                            Cursor="Hand" />
                                    <Button Grid.Column="2"
                                            Height="46"
                                            Padding="28,0"
                                            Content="Kaydet"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Command="{Binding SavePosLayoutCommand}"
                                            Background="{DynamicResource MetroTileGreenBrush}"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Sağ: Önizleme / bilgi kartı -->
                        <Border Grid.Column="2"
                                Padding="20"
                                Background="{DynamicResource ShellContentBackgroundBrush}"
                                BorderBrush="{StaticResource BorderBrushDark}"
                                BorderThickness="1"
                                CornerRadius="20">
                            <StackPanel>
                                <TextBlock Text="Aktif Ayarlar"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="18"
                                           FontWeight="SemiBold" />

                                <Border Margin="0,16,0,0"
                                        Padding="14,12"
                                        Background="{DynamicResource WindowBackgroundBrush}"
                                        BorderBrush="{StaticResource BorderBrushDark}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <StackPanel>
                                        <TextBlock Text="&#x0130;ndirim G&#xF6;r&#xFC;nt&#xFC;leme"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="13" />
                                        <TextBlock Margin="0,6,0,0"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryBrush}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Alt &#x15E;erit" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDiscountDisplayTotalCard}" Value="True">
                                                            <Setter Property="Text" Value="Toplam Kart&#x131;" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,10,0,0"
                                        Padding="14,12"
                                        Background="{DynamicResource WindowBackgroundBrush}"
                                        BorderBrush="{StaticResource BorderBrushDark}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <StackPanel>
                                        <TextBlock Text="Sepet Konumu"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="13" />
                                        <TextBlock Margin="0,6,0,0"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryBrush}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="&#x2190; Sol" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsBasketRight}" Value="True">
                                                            <Setter Property="Text" Value="Sa&#x11F; &#x2192;" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,18,0,0"
                                        Padding="14,12"
                                        Background="{DynamicResource WindowBackgroundBrush}"
                                        CornerRadius="14">
                                    <TextBlock Text="{Binding StatusMessage}"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="13"
                                               TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

            </TabControl>
        </Grid>
    </Border>
    </ScrollViewer>
</UserControl>


