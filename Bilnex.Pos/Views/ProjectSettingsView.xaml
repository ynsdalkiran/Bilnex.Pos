                                            CornerRadius="14"
                                            BorderThickness="2"
                                            Padding="14,12"
                                            Cursor="Hand">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDiscountDisplayStrip}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                                        <Setter Property="Background" Value="{DynamicResource ShellUserPanelBackgroundBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.SavePosLayoutCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="DiscountStrip" />
                                        </Border.InputBindings>
                                        <RadioButton IsChecked="{Binding IsDiscountDisplayStrip, Mode=TwoWay}"
                                                     GroupName="DiscountDisplay"
                                                     Cursor="Hand"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     FocusVisualStyle="{x:Null}">
                                            <StackPanel>
                                                <TextBlock Text="Alt &#x15E;erit"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="&#x0130;ndirimler &#xF6;deme sat&#x131;r&#x131;n&#x131;n &#xFC;st&#xFC;nde ayr&#x131; bir &#x15F;erit olarak g&#xF6;r&#xFC;n&#xFC;r."
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </RadioButton>
                                    </Border>

                                    <!-- Toplam Kartı seçeneği -->
                                    <Border Margin="6,0,0,0"
                                            CornerRadius="14"
                                            BorderThickness="2"
                                            Padding="14,12"
                                            Cursor="Hand">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDiscountDisplayTotalCard}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                                        <Setter Property="Background" Value="{DynamicResource ShellUserPanelBackgroundBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <RadioButton IsChecked="{Binding IsDiscountDisplayTotalCard, Mode=TwoWay}"
                                                     GroupName="DiscountDisplay"
                                                     Cursor="Hand"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     FocusVisualStyle="{x:Null}">
                                            <StackPanel>
                                                <TextBlock Text="Toplam Kart&#x131;"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="&#x0130;ndirimler TOPLAM TUTAR kart&#x131; i&#xE7;inde kompakt olarak g&#xF6;r&#xFC;n&#xFC;r."
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </RadioButton>
                                    </Border>
                                </UniformGrid>

                                <!-- ── Sepet Konumu ── -->
                                <TextBlock Margin="0,24,0,0"
                                           Text="Sepet Konumu"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold" />

                                <UniformGrid Columns="2" Margin="0,10,0,0" Height="110">
                                    <!-- Sol seçeneği -->
                                    <Border Margin="0,0,6,0"
                                            CornerRadius="14"
                                            BorderThickness="2"
                                            Padding="14,12"
                                            Cursor="Hand">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushDark}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsBasketLeft}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                                        <Setter Property="Background" Value="{DynamicResource ShellUserPanelBackgroundBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <RadioButton IsChecked="{Binding IsBasketLeft, Mode=TwoWay}"
