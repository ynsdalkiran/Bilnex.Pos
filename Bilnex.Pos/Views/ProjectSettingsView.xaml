                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Column="2" Padding="24" Background="{DynamicResource ShellUserPanelBackgroundBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="20">
