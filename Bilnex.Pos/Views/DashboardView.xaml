<UserControl x:Class="Bilnex.Pos.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="1000">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1.05*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="0.95*" />
        </Grid.RowDefinitions>

        <Button Grid.Row="0"
                Grid.Column="0"
                Grid.RowSpan="3"
                Command="{Binding DataContext.PosSalesCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                Style="{StaticResource MetroHeroTileStyle}"
                Background="{DynamicResource MetroTileGreenBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="&#xE719;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="42" />

                <StackPanel Grid.Row="1"
                            VerticalAlignment="Center">
                    <TextBlock Text="POS Satis"
                               FontSize="38"
                               FontWeight="Bold" />
                    <TextBlock Margin="0,12,0,0"
                               Text="Barkod okut, sepeti yonet ve odeme al"
                               FontSize="17"
                               Opacity="0.92"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="AKTIF SATIS ALANI"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Opacity="0.82" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Yeni satis baslat"
                               FontSize="15" />
                </StackPanel>
            </Grid>
        </Button>

        <Button Grid.Row="0"
                Grid.Column="2"
                Command="{Binding DataContext.CustomersCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                Style="{StaticResource MetroMenuTileStyle}"
                Background="{DynamicResource MetroTileBlueBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="&#xE77B;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="30" />

                <StackPanel Grid.Row="1"
                            VerticalAlignment="Center">
                    <TextBlock Text="Musteriler"
                               FontSize="24"
                               FontWeight="Bold" />
                    <TextBlock Margin="0,10,0,0"
                               Text="Cari kartlar, bakiyeler ve sadakat"
                               FontSize="14"
                               Opacity="0.92"
                               TextWrapping="Wrap" />
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Text="CARI"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Opacity="0.82" />
            </Grid>
        </Button>

        <Button Grid.Row="0"
                Grid.Column="4"
                Command="{Binding DataContext.InventoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                Style="{StaticResource MetroMenuTileStyle}"
                Background="{DynamicResource MetroTileOrangeBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="&#xE8B7;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="30" />

                <StackPanel Grid.Row="1"
                            VerticalAlignment="Center">
                    <TextBlock Text="Stok"
                               FontSize="24"
                               FontWeight="Bold" />
                    <TextBlock Margin="0,10,0,0"
                               Text="Stok hareketleri, sayim ve fiyat"
                               FontSize="14"
                               Opacity="0.92"
                               TextWrapping="Wrap" />
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Text="ENVANTER"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Opacity="0.82" />
            </Grid>
        </Button>

        <Button Grid.Row="0"
                Grid.Column="6"
                Command="{Binding DataContext.PriceChangeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                Style="{StaticResource MetroMenuTileStyle}"
                Background="#B146C2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="&#xE8AB;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="30" />

                <StackPanel Grid.Row="1"
                            VerticalAlignment="Center">
                    <TextBlock Text="Fiyat Degis"
                               FontSize="24"
                               FontWeight="Bold" />
                    <TextBlock Margin="0,10,0,0"
                               Text="Urun fiyatlarini hizli guncelle"
                               FontSize="14"
                               Opacity="0.92"
                               TextWrapping="Wrap" />
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Text="FIYAT"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Opacity="0.82" />
            </Grid>
        </Button>

        <Grid Grid.Row="2"
              Grid.Column="2"
              Grid.ColumnSpan="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="170" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Row="0"
                    Grid.Column="0"
                    Command="{Binding DataContext.CashCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{StaticResource MetroMenuTileStyle}"
                    Background="{DynamicResource MetroTileTealBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="&#xEAFD;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="30" />

                    <StackPanel Grid.Row="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="Kasa"
                                   FontSize="22"
                                   FontWeight="Bold" />
                        <TextBlock Margin="0,10,0,0"
                                   Text="Kasa bakiye ve manuel islemler"
                                   FontSize="13"
                                   Opacity="0.92"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <TextBlock Grid.Row="2"
                               Text="KASA"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Opacity="0.82" />
                </Grid>
            </Button>

            <Button Grid.Row="0"
                    Grid.Column="2"
                    Command="{Binding DataContext.EndOfDayCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{StaticResource MetroMenuTileStyle}"
                    Background="{DynamicResource MetroTilePurpleBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="&#xE823;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="30" />

                    <StackPanel Grid.Row="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="Gun Sonu"
                                   FontSize="22"
                                   FontWeight="Bold" />
                        <TextBlock Margin="0,10,0,0"
                                   Text="Z raporu, oturum kapama ve ozet"
                                   FontSize="13"
                                   Opacity="0.92"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <TextBlock Grid.Row="2"
                               Text="RAPOR"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Opacity="0.82" />
                </Grid>
            </Button>

            <Button Grid.Row="0"
                    Grid.Column="4"
                    Command="{Binding DataContext.LabelPrintCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{StaticResource MetroMenuTileStyle}"
                    Background="#2B579A">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="&#xE749;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="30" />

                    <StackPanel Grid.Row="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="Etiket Bas"
                                   FontSize="22"
                                   FontWeight="Bold" />
                        <TextBlock Margin="0,10,0,0"
                                   Text="Raf ve urun etiketlerini yazdir"
                                   FontSize="13"
                                   Opacity="0.92"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <TextBlock Grid.Row="2"
                               Text="ETIKET"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Opacity="0.82" />
                </Grid>
            </Button>

            <Button Grid.Row="0"
                    Grid.Column="6"
                    Command="{Binding DataContext.ProjectSettingsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{StaticResource MetroMenuTileStyle}"
                    Background="{DynamicResource MetroTileSlateBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="&#xE713;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="30" />

                    <StackPanel Grid.Row="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="Ayarlar"
                                   FontSize="22"
                                   FontWeight="Bold" />
                        <TextBlock Margin="0,10,0,0"
                                   Text="Yazici, odeme yontemi ve uygulama ayarlari"
                                   FontSize="13"
                                   Opacity="0.92"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <TextBlock Grid.Row="2"
                               Text="AYAR"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Opacity="0.82" />
                </Grid>
            </Button>

            <Border Grid.Row="2"
                    Grid.Column="0"
                    Grid.ColumnSpan="7"
                    Padding="18"
                    Background="#101B2E"
                    CornerRadius="4">
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="Hizli Menu Ozeti"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="Microsoft tile mantigina uygun hizli erisim duzeni."
                                   Foreground="#C4D2E4"
                                   FontSize="13" />
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Right"
                               Text="8 MODUL"
                               Foreground="#7DD3FC"
                               FontSize="22"
                               FontWeight="Bold"
                               VerticalAlignment="Center" />
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
