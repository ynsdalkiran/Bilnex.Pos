<UserControl x:Class="Bilnex.Pos.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="1000">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <Button Grid.Column="0"
                Command="{Binding DataContext.PosSalesCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                Style="{StaticResource PrimaryTileButtonStyle}"
                HorizontalContentAlignment="Left"
                VerticalContentAlignment="Top">
            <StackPanel>
                <TextBlock Text="&#xE719;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="34"
                           Foreground="#BBF7D0" />
                <TextBlock Text="POS Sales"
                           Margin="0,14,0,0"
                           FontSize="36"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Margin="0,10,0,0"
                           Text="New sale, barcode scan, payment, receipt"
                           FontSize="16"
                           Foreground="#D1FAE5" />
            </StackPanel>
        </Button>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="18" />
                <RowDefinition Height="*" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Row="0"
                    Grid.Column="0"
                    Command="{Binding DataContext.CustomersCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{StaticResource TileButtonStyle}"
                    HorizontalContentAlignment="Left"
                    VerticalContentAlignment="Top">
                <StackPanel>
                    <Border Width="52"
                            Height="52"
                            Background="#172554"
                            CornerRadius="14"
                            HorizontalAlignment="Left">
                        <TextBlock Text="C"
                                   Foreground="#93C5FD"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Margin="0,14,0,0"
                               Text="Customers"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="22"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Button>

            <Button Grid.Row="0"
                    Grid.Column="2"
                    Command="{Binding DataContext.InventoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{StaticResource TileButtonStyle}"
                    HorizontalContentAlignment="Left"
                    VerticalContentAlignment="Top">
                <StackPanel>
                    <Border Width="52"
                            Height="52"
                            Background="#3F2B13"
                            CornerRadius="14"
                            HorizontalAlignment="Left">
                        <TextBlock Text="I"
                                   Foreground="#FCD34D"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Margin="0,14,0,0"
                               Text="Inventory"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="22"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Button>

            <Button Grid.Row="2"
                    Grid.Column="0"
                    Command="{Binding DataContext.CashCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{StaticResource TileButtonStyle}"
                    HorizontalContentAlignment="Left"
                    VerticalContentAlignment="Top">
                <StackPanel>
                    <Border Width="52"
                            Height="52"
                            Background="#173126"
                            CornerRadius="14"
                            HorizontalAlignment="Left">
                        <TextBlock Text="$"
                                   Foreground="#86EFAC"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Margin="0,14,0,0"
                               Text="Cash"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="22"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Button>

            <Button Grid.Row="2"
                    Grid.Column="2"
                    Command="{Binding DataContext.EndOfDayCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{StaticResource TileButtonStyle}"
                    HorizontalContentAlignment="Left"
                    VerticalContentAlignment="Top">
                <StackPanel>
                    <Border Width="52"
                            Height="52"
                            Background="#3E1F35"
                            CornerRadius="14"
                            HorizontalAlignment="Left">
                        <TextBlock Text="E"
                                   Foreground="#F9A8D4"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Margin="0,14,0,0"
                               Text="End of Day"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="22"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Button>

            <Button Grid.Row="4"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Command="{Binding DataContext.ProjectSettingsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{StaticResource TileButtonStyle}"
                    HorizontalContentAlignment="Left"
                    VerticalContentAlignment="Top">
                <StackPanel>
                    <Border Width="52"
                            Height="52"
                            Background="#2E2450"
                            CornerRadius="14"
                            HorizontalAlignment="Left">
                        <TextBlock Text="S"
                                   Foreground="#C4B5FD"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Project Settings"
                               Margin="0,14,0,0"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Margin="0,10,0,0"
                               Text="Company info, devices, receipt, pricing and app configuration"
                               FontSize="14"
                               Foreground="{StaticResource TextMutedBrush}" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</UserControl>
