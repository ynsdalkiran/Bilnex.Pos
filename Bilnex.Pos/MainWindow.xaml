<Window x:Class="Bilnex.Pos.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Bilnex POS"
        Width="1440"
        Height="820"
        MinWidth="1024"
        MinHeight="768"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="Manual"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        KeyDown="Window_KeyDown"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="22" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="Transparent"
                MouseLeftButtonDown="DragStrip_MouseLeftButtonDown" />

        <Border Grid.Row="1"
                Padding="24,20"
                Background="{DynamicResource ShellHeaderBackgroundBrush}"
                BorderBrush="{DynamicResource ShellHeaderBorderBrush}"
                BorderThickness="1"
                CornerRadius="26"
                Visibility="{Binding IsDashboardViewActive, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <Border Width="108"
                            Height="28"
                            Padding="10,5"
                            Margin="0,0,0,12"
                            HorizontalAlignment="Left"
                            Background="{DynamicResource ShellBadgeBackgroundBrush}"
                            CornerRadius="15">
                        <TextBlock Text="ANA PANEL"
                                   Foreground="{DynamicResource ShellBadgeTextBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Text="{Binding AppTitle}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="30"
                               FontWeight="Bold" />

                    <TextBlock Margin="0,8,0,0"
                               Text="Perakende işlemleri, satış akışı ve günlük mağaza yönetimine hızlı erişim."
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="14" />
                </StackPanel>

                <Border Grid.Column="1"
                        MinWidth="360"
                        Padding="16,14"
                        Margin="20,0,0,0"
                        Background="{DynamicResource ShellUserPanelBackgroundBrush}"
                        BorderBrush="{DynamicResource ShellHeaderBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="20"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Width="42"
                                Height="42"
                                Background="{DynamicResource ShellUserBadgeBackgroundBrush}"
                                CornerRadius="14"
                                VerticalAlignment="Center">
                            <TextBlock Text="U"
                                       Foreground="{DynamicResource ShellUserBadgeTextBrush}"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Column="2"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentUser}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding BranchName}"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="12" />
                        </StackPanel>

                        <Button Grid.Column="4"
                                Width="100"
                                Height="40"
                                Command="{Binding ExitCommand}"
                                Background="{DynamicResource ShellExitBackgroundBrush}"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Style="{StaticResource DangerActionButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8BB;"
                                           Margin="0,0,8,0"
                                           FontFamily="Segoe MDL2 Assets"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Çıkış"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Padding="16"
                Background="{DynamicResource ShellContentBackgroundBrush}"
                BorderBrush="{DynamicResource ShellContentBorderBrush}"
                BorderThickness="1"
                CornerRadius="28">
            <ContentControl Content="{Binding CurrentView}" />
        </Border>

        <ItemsControl Grid.RowSpan="4"
                      Margin="0,16,16,0"
                      Panel.ZIndex="20"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      ItemsSource="{Binding NotificationCenter.Toasts}"
                      IsHitTestVisible="False">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Width="360"
                            Margin="0,0,0,12"
                            Padding="16"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{Binding AccentBrush}"
                            BorderThickness="1,1,1,1"
                            CornerRadius="18"
                            Opacity="0">
                        <Border.RenderTransform>
                            <TranslateTransform X="96" />
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0"
                                                         To="0.98"
                                                         Duration="0:0:0.30">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                         From="96"
                                                         To="0"
                                                         Duration="0:0:0.34">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase Amplitude="0.18"
                                                          EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Width="48"
                                    Height="48"
                                    Background="{Binding AccentBrush}"
                                    CornerRadius="14"
                                    VerticalAlignment="Top">
                                <TextBlock Text="{Binding IconGlyph}"
                                           FontFamily="Segoe MDL2 Assets"
                                           Foreground="White"
                                           FontSize="22"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="2">
                                <Border HorizontalAlignment="Left"
                                        Padding="8,3"
                                        Background="{Binding AccentBrush}"
                                        CornerRadius="9">
                                    <TextBlock Text="{Binding AccentLabel}"
                                               Foreground="White"
                                               FontSize="11"
                                               FontWeight="Bold" />
                                </Border>

                                <TextBlock Margin="0,10,0,0"
                                           Text="{Binding Title}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap" />

                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding Caption}"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />

                                <TextBlock Margin="0,10,0,0"
                                           Text="{Binding Message}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontSize="14"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Grid.RowSpan="4"
              Panel.ZIndex="30"
              Background="#8C020617"
              Visibility="{Binding NotificationCenter.HasActiveOverlay, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Width="720"
                    MaxWidth="720"
                    Padding="28"
                    Background="{DynamicResource ShellContentBackgroundBrush}"
                    BorderBrush="{DynamicResource ShellHeaderBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="28"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel DataContext="{Binding NotificationCenter.ActiveOverlay}">
                    <Border Height="8"
                            Margin="-28,-28,-28,0"
                            Background="{Binding AccentBrush}"
                            CornerRadius="28,28,0,0" />

                    <Grid Margin="0,24,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Width="76"
                                Height="76"
                                Background="{Binding AccentBrush}"
                                CornerRadius="22"
                                VerticalAlignment="Top">
                            <TextBlock Text="{Binding IconGlyph}"
                                       FontFamily="Segoe MDL2 Assets"
                                       Foreground="White"
                                       FontSize="34"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Column="2"
                                    VerticalAlignment="Center">
                            <Border HorizontalAlignment="Left"
                                    Padding="10,4"
                                    Background="{Binding AccentBrush}"
                                    CornerRadius="10">
                                <TextBlock Text="{Binding AccentLabel}"
                                           Foreground="White"
                                           FontSize="12"
                                           FontWeight="Bold" />
                            </Border>

                            <TextBlock Margin="0,12,0,0"
                                       Text="{Binding Title}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap" />

                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding Caption}"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>

                    <Border Margin="0,24,0,0"
                            Padding="22"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="18">
                        <TextBlock Text="{Binding Message}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                    </Border>

                    <Button Width="220"
                            Height="72"
                            Margin="0,24,0,0"
                            HorizontalAlignment="Right"
                            Command="{Binding DataContext.NotificationCenter.DismissOverlayCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{StaticResource PrimaryActionButtonStyle}">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="&#xE73E;"
                                       Margin="0,0,10,0"
                                       FontFamily="Segoe MDL2 Assets"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ButtonText}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
        </Grid>
    </Grid>
</Window>

